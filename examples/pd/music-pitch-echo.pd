#N canvas 0 0 950 700 12;
#X text 30 15 Pitch Echo - SoundCue Music Info;
#X text 30 35 pitch -> osc freq \, rms -> volume \, centroid -> filter;
#X text 30 55 Detected pitch controls oscillator with delay/echo effect;
#X obj 50 100 else/osc.receive 8000;
#X obj 50 140 else/osc.route /music;
#X obj 50 190 else/osc.route /pitch /rms /centroid;
#X text 50 170 --- pitch (Hz) ----- rms (0-1) ----- centroid (Hz) ---;
#X obj 50 240 else/smooth 80;
#X obj 50 280 cyclone/scale 80 1000 80 1000;
#X text 200 285 pitch -> osc freq;
#X obj 300 240 else/smooth 50;
#X obj 300 280 cyclone/scale 0 0.5 0 0.4;
#X text 450 285 rms -> volume;
#X obj 550 240 else/smooth 50;
#X obj 550 280 cyclone/scale 200 4000 300 5000;
#X text 700 285 centroid -> filter freq;
#X obj 50 350 osc~;
#X obj 50 390 vcf~ 0 5;
#X obj 50 430 *~;
#X obj 50 480 delwrite~ echo_delay 500;
#X obj 250 480 delread~ echo_delay 250;
#X obj 250 520 *~ 0.4;
#X obj 50 530 +~;
#X obj 50 580 *~ 0.5;
#X obj 50 630 else/out~ 1;
#X connect 3 0 4 0;
#X connect 4 0 5 0;
#X connect 5 0 7 0;
#X connect 5 1 10 0;
#X connect 5 2 13 0;
#X connect 7 0 8 0;
#X connect 8 0 16 0;
#X connect 10 0 11 0;
#X connect 11 0 18 1;
#X connect 13 0 14 0;
#X connect 14 0 17 1;
#X connect 16 0 17 0;
#X connect 17 0 18 0;
#X connect 18 0 19 0;
#X connect 18 0 22 0;
#X connect 20 0 21 0;
#X connect 21 0 22 1;
#X connect 22 0 23 0;
#X connect 23 0 24 0;
